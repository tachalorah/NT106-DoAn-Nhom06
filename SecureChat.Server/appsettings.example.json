// Cóp tệp này thành appsettings.json, sửa "Default" bên dưới cho đúng cấu hình MariaDB & Email.

{
  "ConnectionStrings": {
    "Default": "Server=@address;Port=@port;Database=@database_name;Uid=@userPwd=@password;",
  }

  "EmailSettings": {
    "SmtpHost": "@smtpserver",
    "SmtpPort": @smtpport,
    "EnableSsl": true,
    "SenderEmail": "email@handle",
    "SenderPassword": "@secret",
    "SenderName": "SecureChat"
  },

  "Jwt": {
    "Issuer": "SecureChatServer",
    "Audience": "SecureChatClient",
    "Key": "REPLACE_WITH_A_SECRET_KEY_AT_LEAST_32_CHARS_LONG",
    "AccessTokenMinutes": "15",
    "RefreshTokenDays": "30"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
